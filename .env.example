# ═══════════════════════════════════════════════════════════
# Smart Student Career Assistant — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All VITE_ prefixed vars are exposed to the client bundle.
# ═══════════════════════════════════════════════════════════

# Firebase Configuration
# Find these at: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# Google Gemini AI
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123def456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────
# SERVER-SIDE ONLY (Cloud Functions)
# ─────────────────────────────────────────────────────────
# The Gemini API key is set via Firebase Functions config,
# NOT in this file. Run:
#   firebase functions:config:set gemini.api_key="YOUR_KEY"
#
# To verify:
#   firebase functions:config:get
# ─────────────────────────────────────────────────────────
